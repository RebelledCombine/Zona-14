z14-anomaly-migration-warning = Anomaly migration detected. The zone layout is about to shift.
z14-anomaly-migration-start = Anomaly migration detected in { $map }. The zone layout is about to shift.
z14-anomaly-migration-end = Anomaly migration in { $map } has completed. The zone has shifted.
z14-anomaly-migration-start-all = Anomaly migration detected across the zone. The anomaly layout is about to shift.
z14-anomaly-migration-end-all = Anomaly migration across the zone has completed. The anomaly layout has shifted.

cmd-z14anomigrate-description = Manually trigger an anomaly migration on a map.
cmd-z14anomigrate-help = Usage: z14anomigrate [mapKey|mapId] [count]
