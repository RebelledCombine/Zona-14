ent-Z14CraftBag = мешок
    .desc = { ent-CraftGunpowderBank.suffix }
    .suffix = Z14

ent-Z14CraftCardboardTube = картонная труба
    .desc = Труба из картона, видимо кто-то хочет сделать подзорную трубу либо взрывчатку.
    .suffix = Z14

ent-Z14CraftFerments = набор ферментизации
    .desc = Одноразовый набор ферментизации, следует применять крайне осторожно.
    .suffix = Z14

ent-Z14CraftFitil = фитиль
    .desc = Скрутка из фитиля, используется для поджигания или поддержания огня, особенно в свечах.
    .suffix = Z14

ent-Z14CraftGunpowderBank = баночка с порохом
    .desc = Предназначенна для хранения пороха, используемого в огнестрельном оружии или пиротехнических устройства. В частом случае создания боеприпасов.
    .suffix = Z14

ent-Z14CraftHide = шкура
    .desc = Необработанная шкура животного.
    .suffix = Z14

ent-Z14CraftHideBloodSucker = шкура мутанта
    .desc = Необработанная шкура кровососа, достаточно крепкая.
    .suffix = Z14

ent-Z14CraftLargeCardboard = большой картон
    .desc = Картон из под какой-то большой коробки.
    .suffix = Z14

ent-Z14CraftMaterialGunpowder = чёрный порох
    .desc = Взрывчатое соединение.
    .suffix = Z14

ent-Z14CraftSmallCardboard = маленький картон
    .desc = Картон из под какой-то коробки либо подрезанный.
    .suffix = Z14

ent-Z14PartRodMetalStalker = металические трубы
    .desc = { ent-CraftGunpowderBank.desc }
    .suffix = Z14

ent-Z14StickDynamite = динамитная шашка без фитиля
    .desc = { ent-StickDynamite.desc }
    .suffix = Z14
