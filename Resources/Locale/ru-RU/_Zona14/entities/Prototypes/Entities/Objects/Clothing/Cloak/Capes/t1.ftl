ent-Z14ClothingCapeDeserters = плащ дезертиров
    .desc = Кусок ткани в пиксельном тёмно-сером камуфляже, при желании можно носить как плащ
    .suffix = Z14

ent-Z14ClothingCapeRenegat = плащ ренегатов
    .desc = Кусок ткани в пиксельном какашном камуфляже, при желании можно носить как плащ
    .suffix = Z14

ent-Z14ClothingHeadCassock = капюшон рясы
    .desc = капюшон из грубой ткани от монашеской рясы
    .suffix = Z14

ent-Z14ClothingHeadHatHoodCoatPoisk = капюшон
    .desc = Элемент снаряжения Зоны.
    .suffix = Z14

ent-Z14ClothingHeadHelmetDoshdevikCoat = капюшон дождевика
    .desc = Покрывает вашу голову
    .suffix = Z14

ent-Z14ClothingHeadHelmetKKKCoat = капирот
    .desc = Средневековый испанский головной убор, остроконечный колпак конической формы. Первоначально изготовленные из картона капироты применялись испанскими флагеллантами. Во времена инквизиции обтянутые тканью капироты наряду с желтыми накидками использовались для облачения осужденных на смертную казнь.
    .suffix = Z14

ent-Z14ClothingHeadHelmetPahanCoat = капюшон плаща пахана
    .desc = Покрывает вашу голову
    .suffix = Z14

ent-Z14ClothingHeadHelmetSeraRuined = капюшон
    .desc = Драный капюшон странного цвета.
    .suffix = Z14

ent-Z14ClothingNeckCloakCassock = ряса паломника
    .desc = сделана из грубой ткани серой ткани, помогает отречься от мирского
    .suffix = Z14

ent-Z14ClothingOuterCoatDoshdevik = дождевик
    .desc = плотный плащ с защищающий вас от дождя и некоторых химикатов.
    .suffix = Z14

ent-Z14ClothingOuterCoatKKK = балахон ку-клукс-клана
    .desc = Белые балахоны Ку-Клукс-Клана, представляют собой длинные белые одежды с капюшонами, которые символизируют анонимность и единство членов организации. Эти балахоны часто ассоциируются с расистскими действиями ККК, подчеркивая их идеологию превосходства белой расы.
    .suffix = Z14

ent-Z14ClothingOuterCoatPahan = плащ пахана
    .desc = плотный плащ перекрашенный в чёрный цвет.
    .suffix = Z14

ent-Z14ClothingOuterCoatPoisk = плащ исследователя
    .desc = Этот плащ не просто украшение, он символизирует стремление к приключениям и жажду открытий.
    .suffix = Z14

ent-Z14ClothingTorsoTurtlenecksCamouflage = рваный плащ выживших
    .desc = Странный плащ, рваный в хлам. Кустарно перекрашен в какой-то камуфляж.
    .suffix = Z14

ent-Z14STClothingCapeT1Serafim = плащ серафимов
    .desc = Выполнен в тёмно-зелёной цветовой гамме
    .suffix = Z14

ent-Z14STClothingHeadHelmetSerafim = капюшон плаща серафимов
    .desc = Покрывает вашу голову
    .suffix = Z14
