ent-Z14ClothingOuterArmorSevaVano = костюм "Сева" М1 V.A.N.O
    .desc = Сева, сделанная народным умельцем, имеет улучшенные характеристики как для боя с мутантами, так и с недоброжелателями. Модифицирована пластинами из композитных материалов и прошита поликарбонатной нитью. Руки и ноги окрашены белым цветом, нагрудник и шлем, напротив, - чёрным. На нагруднике виднеется белый череп.
    .suffix = Z14

ent-Z14STClothingHeadPeresvet = шлем бронекомбеза "Пересвет" #base
