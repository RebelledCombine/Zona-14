#!/usr/bin/env bash
# Zona-14 pre-commit hook — runs convention checks before each commit.
# Install: git config core.hooksPath Tools/_Zona14/hooks
#
# Requires: jq (sudo apt install jq / brew install jq).
# Skips gracefully if jq is missing (prints a warning instead of blocking).

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
SCRIPT="$REPO_ROOT/Tools/_Zona14/check-conventions.sh"

if [[ ! -f "$SCRIPT" ]]; then
    echo "pre-commit: check-conventions.sh not found at $SCRIPT — skipping." >&2
    exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
    echo "pre-commit: WARNING — 'jq' not installed; skipping convention check." >&2
    echo "  Install with: sudo apt install jq  (or: brew install jq)" >&2
    exit 0
fi

# Check the staged commit (the actual changes being committed). The script's
# --cached mode uses `git diff --cached` and ignores the positional refs.
bash "$SCRIPT" --cached
